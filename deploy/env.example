# Router and container
ROUTER_ALIAS=router
HERMES_CONTAINER=ubuntu2
HERMES_HOME=/config/.hermes
HERMES_BIN=/config/.local/bin/hermes
HERMES_VENV_PY=/config/.hermes/hermes-agent/venv/bin/python3

# LAN-only ports
HERMES_WEB_UI_PORT=8670
HERMES_GATEWAY_PORT=8642
HERMES_WECHAT_PORT=8643
HERMES_MEME_PORT=8646
HERMES_RISK_PORT=8647
HERMES_QUANT_PORT=8648

# Model provider. Keep real values out of Git.
HERMES_MODEL_PROVIDER=custom
HERMES_MODEL=mimo-v2.5
HERMES_MODEL_BASE_URL=https://example.invalid/v1
HERMES_MODEL_API_KEY=replace_me

# Optional outbound proxy. Leave empty if not needed.
HERMES_PROXY_URL=
HERMES_NO_PROXY=localhost,127.0.0.1,::1,172.17.0.0/16,192.168.0.0/16,10.0.0.0/8

# Optional external integrations. Replace locally only.
TELEGRAM_BOT_TOKEN=replace_me
WECHAT_TOKEN=replace_me
TSDB_URL=postgres://user:password@example.invalid:5432/db
REDIS_URL=redis://:password@example.invalid:6379/0

